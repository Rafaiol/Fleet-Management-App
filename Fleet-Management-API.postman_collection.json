            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/api/vehicles",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"plateNumber\": \"ABC-1234\",\n  \"make\": \"Toyota\",\n  \"model\": \"Camry\",\n  \"year\": 2022,\n  \"vin\": \"VIN123456789\",\n  \"color\": \"White\",\n  \"bodyType\": \"sedan\",\n  \"fuelType\": \"gasoline\",\n  \"transmission\": \"automatic\",\n  \"currentMileage\": 15000,\n  \"status\": \"active\"\n}"
            }
          }
        },
        {
          "name": "Update Vehicle",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/api/vehicles/{{vehicleId}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"currentMileage\": 20000,\n  \"status\": \"maintenance\"\n}"
            }
          }
        },
        {
          "name": "Delete Vehicle",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/vehicles/{{vehicleId}}"
