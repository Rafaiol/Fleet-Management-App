          "name": "Update Vehicle Mileage",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/api/vehicles/{{vehicleId}}/mileage",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"mileage\": 25000\n}"
            }
          }
        },
        {
          "name": "Get Vehicles Needing Maintenance",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/vehicles/maintenance/due?days=30",
              "query": [{ "key": "days", "value": "30" }]
            }
          }
        }
      ]
    },
    {
      "name": "Maintenance",
      "item": [
        {
          "name": "Get All Maintenance Records",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/maintenance?page=1&limit=10",
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" },
                { "key": "status", "value": "" },
                { "key": "type", "value": "" }
              ]
            }
          }
        },
        {
          "name": "Get Maintenance by ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/maintenance/{{maintenanceId}}"
          }
        },
        {
          "name": "Create Maintenance Record",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/api/maintenance",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"vehicle\": \"{{vehicleId}}\",\n  \"type\": \"oil_change\",\n  \"scheduledDate\": \"2024-12-25T10:00:00Z\",\n  \"description\": \"Regular oil change service\",\n  \"priority\": \"medium\",\n  \"mileageAtService\": 25000,\n  \"partsUsed\": [\n    {\n      \"name\": \"Oil Filter\",\n      \"partNumber\": \"OF-123\",\n      \"quantity\": 1,\n      \"unitPrice\": 15.99\n    },\n    {\n      \"name\": \"Engine Oil\",\n      \"quantity\": 5,\n      \"unitPrice\": 8.99\n    }\n  ],\n  \"laborHours\": 1.5,\n  \"laborRate\": 50\n}"
            }
          }
        },
        {
          "name": "Update Maintenance Record",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/api/maintenance/{{maintenanceId}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"in_progress\"\n}"
            }
          }
        },
        {
          "name": "Delete Maintenance Record",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/maintenance/{{maintenanceId}}"
          }
        },
        {
          "name": "Complete Maintenance",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/api/maintenance/{{maintenanceId}}/complete",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"workPerformed\": \"Changed oil and oil filter, checked all fluid levels\",\n  \"mileageAtService\": 25500,\n  \"completionDate\": \"2024-12-25T14:00:00Z\"\n}"
            }
          }
        },
        {
          "name": "Get Maintenance Stats",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/maintenance/stats/overview?startDate=2024-01-01&endDate=2024-12-31",
              "query": [
                { "key": "startDate", "value": "2024-01-01" },
                { "key": "endDate", "value": "2024-12-31" }
              ]
            }
          }
        },
        {
          "name": "Get Maintenance Types",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/maintenance/filters/types"
